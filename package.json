{
	"name": "ctrl.page",
	"private": true,
	"workspaces": [
		"packages/apps/*",
		"packages/libs/*",
		"packages/infra/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"dev:desktop": "turbo dev dev:watch-ui storybook --filter=@ctrl/desktop --filter=@ctrl/core.ui",
		"build": "turbo build",
		"check": "turbo check",
		"lint": "biome check . && bunx grit check .",
		"lint:fix": "biome check --write .",
		"fmt": "biome format --write .",
		"test": "turbo test"
	},
	"packageManager": "bun@1.3.9",
	"dependencies": {
		"@effect/platform": "latest",
		"@effect/platform-bun": "latest",
		"@libsql/client": "latest",
		"@zag-js/solid": "^1.36.0",
		"drizzle-orm": "latest",
		"effect": "latest",
		"electrobun": "1.15.1",
		"solid-js": "latest"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@dschz/bun-plugin-solid": "^1.0.4",
		"@getgrit/cli": "^0.1.0-alpha.1743007075",
		"@pandacss/dev": "latest",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@types/bun": "latest",
		"@typescript/native-preview": "latest",
		"drizzle-kit": "latest",
		"lefthook": "^2.1.4",
		"semantic-release": "^25.0.3",
		"storybook": "^10.0.0",
		"storybook-solidjs": "1.0.0-beta.6",
		"storybook-solidjs-vite": "^10.0.0",
		"turbo": "latest",
		"vite": "^6.0.0",
		"vite-plugin-solid": "latest"
	},
	"version": "0.3.0"
}
