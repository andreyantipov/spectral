{
	"name": "ctrl.page",
	"private": true,
	"workspaces": [
		"packages/apps/*",
		"packages/libs/*",
		"packages/infra/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"dev:desktop": "turbo dev dev:watch-ui storybook --filter=@ctrl/desktop --filter=@ctrl/core.ui",
		"build": "turbo build",
		"check": "turbo check",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"fmt": "biome format --write .",
		"test": "turbo test"
	},
	"packageManager": "bun@1.3.9",
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@typescript/native-preview": "latest",
		"turbo": "latest"
	}
}
