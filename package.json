{
	"name": "spectral",
	"private": true,
	"workspaces": [
		"packages/apps/*",
		"packages/libs/*",
		"packages/infra/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"dev:desktop": "turbo dev dev:watch-ui storybook --filter=@ctrl/desktop --filter=@ctrl/core.ui.components --filter=@ctrl/infra.otel",
		"dev:desktop:agentic": "turbo dev --filter=@ctrl/desktop --ui=stream --log-order=stream",
		"dev:app": "cd packages/apps/desktop && bun run prebundle && npx electrobun dev",
		"build": "turbo build",
		"check": "turbo check",
		"lint": "biome check . && ast-grep scan",
		"lint:fix": "biome check --write .",
		"fmt": "biome format --write .",
		"build:ci": "turbo build --filter=!@ctrl/desktop",
		"lint:ci": "biome check . && ast-grep scan",
		"test": "turbo test",
		"docs:meta": "bun run packages/tools/extract-metadata.ts > metadata.json",
		"docs:generated": "bun run packages/tools/extract-metadata.ts --format=markdown > docs/architecture/GENERATED.md",
		"docs:catalog": "bun run packages/tools/generate-catalog.ts packages/apps/dev-docs",
		"docs:deps": "bunx depcruise --config .dependency-cruiser.cjs --output-type archi packages/libs/ | dot -Grankdir=TB -Granksep=1.5 -Gnodesep=0.8 -T svg > docs/architecture/dependency-graph.svg",
		"docs:deps:validate": "bunx depcruise --validate .dependency-cruiser.cjs packages/libs/",
		"docs:build": "bun run docs:meta && bun run docs:generated && bun run docs:catalog && bun run docs:deps:validate",
		"docs:catalog:dev": "bun run docs:meta && bun run docs:catalog && turbo dev --filter=@ctrl/dev-docs",
		"docs:catalog:watch": "bun run packages/tools/watch-catalog.ts"
	},
	"packageManager": "bun@1.3.9",
	"dependencies": {
		"@effect/experimental": "^0.58.0",
		"@effect/opentelemetry": "^0.61.0",
		"@effect/platform": "^0.94.5",
		"@effect/platform-bun": "^0.87.1",
		"@effect/rpc": "^0.73.2",
		"@effect/rpc-http": "^0.52.4",
		"@effect/schema": "^0.75.5",
		"@effect/sql": "^0.49.0",
		"@effect/sql-drizzle": "^0.48.1",
		"@effect/sql-libsql": "^0.39.0",
		"@libsql/client": "^0.17.0",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
		"@opentelemetry/resources": "^2.6.0",
		"@opentelemetry/sdk-trace-base": "^2.6.0",
		"@opentelemetry/sdk-trace-node": "^2.6.0",
		"@opentelemetry/sdk-trace-web": "^2.6.0",
		"@zag-js/solid": "^1.36.0",
		"@zag-js/toast": "^1.36.0",
		"dockview-core": "^5.1.0",
		"drizzle-orm": "^0.45.1",
		"effect": "^3.19.19",
		"electrobun": "1.15.1",
		"solid-js": "^1.9.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@dschz/bun-plugin-solid": "^1.0.4",
		"@effect/language-service": "^0.84.2",
		"@eventcatalog/sdk": "^2.18.3",
		"@modelcontextprotocol/sdk": "^1.28.0",
		"@pandacss/dev": "^1.9.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@types/bun": "^1.3.10",
		"@typescript/native-preview": "^7.0.0-dev.20260301.1",
		"dependency-cruiser": "^17.3.10",
		"drizzle-kit": "^0.31.9",
		"lefthook": "^2.1.4",
		"semantic-release": "^25.0.3",
		"storybook": "^10.0.0",
		"storybook-solidjs": "1.0.0-beta.6",
		"storybook-solidjs-vite": "^10.0.0",
		"ts-morph": "^27.0.2",
		"turbo": "^2.8.12",
		"vite": "^6.0.0",
		"vite-plugin-solid": "^2.11.10",
		"vitest": "^4.1.0",
		"zod": "^4.3.6"
	},
	"version": "0.15.0"
}
