{
	"mcpServers": {
		"effect-mcp": {
			"command": "npx",
			"args": ["effect-mcp@latest"]
		},
		"architecture": {
			"command": "bun",
			"args": ["run", "packages/tools/mcp-architecture.ts"]
		},
		"ast-grep": {
			"command": "uvx",
			"args": ["--from", "git+https://github.com/ast-grep/ast-grep-mcp@main", "ast-grep-server"]
		},
		"ollama": {
			"command": "npx",
			"args": ["-y", "ollama-mcp"],
			"env": {
				"OLLAMA_HOST": "http://lab.lan:11434"
			}
		}
	}
}
