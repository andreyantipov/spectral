{
	"name": "@ctrl/desktop",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"dependencies": {
		"@ctrl/core.port.event-bus": "workspace:*",
		"@ctrl/core.shared": "workspace:*",
		"@ctrl/core.ui": "workspace:*",
		"@ctrl/domain.adapter.db": "workspace:*",
		"@ctrl/domain.adapter.electrobun": "workspace:*",
		"@ctrl/domain.adapter.otel": "workspace:*",
		"@ctrl/domain.adapter.rpc": "workspace:*",
		"@ctrl/domain.feature.bookmark": "workspace:*",
		"@ctrl/domain.feature.history": "workspace:*",
		"@ctrl/domain.feature.omnibox": "workspace:*",
		"@ctrl/domain.feature.session": "workspace:*",
		"@ctrl/domain.feature.layout": "workspace:*",
		"@ctrl/domain.service.browsing": "workspace:*",
		"@ctrl/domain.service.workspace": "workspace:*",
		"@ctrl/ui.scenes": "workspace:*",
		"electrobun": "1.15.1"
	},
	"scripts": {
		"prebundle": "bun run build-view.ts && bun run prepare-native-deps.ts",
		"build": "bun install && bun run prebundle && electrobun build --env stable",
		"start": "bun run build && electrobun dev",
		"dev": "bun run prebundle && electrobun dev --watch",
		"dev:watch-ui": "bun run dev-view.ts",
		"check": "tsgo --noEmit 2>&1 | (! grep -v 'node_modules/' | grep 'error TS')"
	}
}
