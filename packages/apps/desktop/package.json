{
	"name": "@ctrl/desktop",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"dependencies": {
		"@ctrl/arch.contract.event-bus": "workspace:*",
		"@ctrl/arch.impl.db": "workspace:*",
		"@ctrl/base.schema": "workspace:*",
		"@ctrl/base.spec.web-session": "workspace:*",
		"@ctrl/base.tracing": "workspace:*",
		"@ctrl/base.type": "workspace:*",
		"@ctrl/feature.system.settings": "workspace:*",
		"@ctrl/ui.base.api": "workspace:*",
		"@ctrl/ui.base.components": "workspace:*",
		"@ctrl/ui.scene.main": "workspace:*",
		"@ctrl/wire.desktop.main": "workspace:*",
		"@ctrl/wire.desktop.ui": "workspace:*",
		"electrobun": "1.15.1"
	},
	"scripts": {
		"prebundle": "bun run build-view.ts && bun run prepare-native-deps.ts",
		"prebundle:bun": "bun build src/bun/index.ts --target=bun --external=@libsql/client --outfile=build/index.js",
		"build": "bun install && bun run prebundle && bun run prebundle:bun && electrobun build --env stable",
		"start": "bun run build && electrobun dev",
		"dev": "bun run prebundle && bun run prebundle:bun && electrobun dev --watch",
		"dev:watch-ui": "bun run dev-view.ts",
		"check": "tsgo --noEmit 2>&1 | (! grep -v 'node_modules/' | grep 'error TS')"
	}
}
