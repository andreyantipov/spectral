{
	"name": "@ctrl/desktop",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"dependencies": {
		"@ctrl/core.base.model": "workspace:*",
		"@ctrl/core.base.tracing": "workspace:*",
		"@ctrl/core.base.types": "workspace:*",
		"@ctrl/core.port.event-bus": "workspace:*",
		"@ctrl/core.port.storage": "workspace:*",
		"@ctrl/core.ui": "workspace:*",
		"@ctrl/domain.adapter.db": "workspace:*",
		"@ctrl/domain.adapter.otel": "workspace:*",
		"@ctrl/domain.service.native": "workspace:*",
		"@ctrl/domain.runtime.bun": "workspace:*",
		"@ctrl/domain.runtime.webview": "workspace:*",
		"@ctrl/ui.scenes": "workspace:*",
		"electrobun": "1.15.1"
	},
	"scripts": {
		"prebundle": "bun run build-view.ts && bun run prepare-native-deps.ts",
		"prebundle:bun": "bun build src/bun/index.ts --target=bun --external=@libsql/client --outfile=build/bun-entry.js",
		"build": "bun install && bun run prebundle && bun run prebundle:bun && electrobun build --env stable",
		"start": "bun run build && electrobun dev",
		"dev": "bun run prebundle && electrobun dev --watch",
		"dev:watch-ui": "bun run dev-view.ts",
		"check": "tsgo --noEmit 2>&1 | (! grep -v 'node_modules/' | grep 'error TS')"
	}
}
