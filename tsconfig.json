{
	"compilerOptions": {
		"strict": true,
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"plugins": [{ "name": "@effect/language-service" }],
		"paths": {
			"@ctrl/*": ["./packages/libs/*/src"],
			"@ctrl/apps/*": ["./packages/apps/*/src"],
			"@ctrl/infra/*": ["./packages/infra/*/src"],
			"@styled-system/*": ["./packages/libs/ui.base.components/styled-system/*"]
		}
	},
	"exclude": ["node_modules", ".bun", "dist"]
}
